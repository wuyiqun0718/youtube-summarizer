# Qwen (通义千问) API Key for LLM summarization
# Get your key from: https://dashscope.console.aliyun.com/
# Leave empty to use placeholder summarization
QWEN_API_KEY=

# --- Tool paths (override if not in PATH) ---
# BIN_YTDLP=yt-dlp
# BIN_FFMPEG=ffmpeg
# BIN_PYTHON=python3
# BIN_WHISPER=whisper-cli

# Extra PATH prefix (default: /opt/homebrew/bin on macOS, empty on others)
# EXTRA_PATH=

# HTTP proxy for yt-dlp / ffmpeg (default: http://127.0.0.1:7897, set empty to disable)
# PROXY_URL=http://127.0.0.1:7897
